    "t1Role": "\u0639\u0645\u064a\u0644\u0629",
    "t1Text": "\u0648\u062c\u062f\u062a \u0645\u0639\u0644\u0645 \u0625\u0646\u062c\u0644\u064a\u0632\u064a\u0629 \u0631\u0627\u0626\u0639 \u0639\u0644\u0649 \u0628\u064a\u0628 \u0641\u064a \u062f\u0642\u0627\u0626\u0642. \u062c\u0648\u062f\u0629 \u0627\u0644\u0641\u064a\u062f\u064a\u0648 \u0643\u0627\u0646\u062a \u0645\u0645\u062a\u0627\u0632\u0629 \u0648\u0627\u0644\u062d\u062c\u0632 \u0643\u0627\u0646 \u0633\u0644\u0633. \u0646\u062a\u064a\u062c\u062a\u064a \u0641\u064a IELTS \u0627\u0631\u062a\u0641\u0639\u062a \u0645\u0646 6.0 \u0625\u0644\u0649 7.5 \u0641\u064a \u0634\u0647\u0631\u064a\u0646 \u0641\u0642\u0637!",
