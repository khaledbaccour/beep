# Backend API URL (include /api/v1 for the API client)
NEXT_PUBLIC_API_URL=http://localhost:3003/api/v1

# PeerJS signaling server (for video calls)
# Local dev: localhost:9000, Production: 0.peerjs.com:443
NEXT_PUBLIC_PEERJS_HOST=localhost
NEXT_PUBLIC_PEERJS_PORT=9000
NEXT_PUBLIC_PEERJS_PATH=/peer

# Gammal Tech Payment SDK
# NEXT_PUBLIC_GAMMAL_TECH_SDK_URL=https://api.gammal.tech/sdk-web.js
# NEXT_PUBLIC_GAMMAL_TECH_DOMAIN=beep.tn

# Dev payment bypass: skip Gammal Tech popup, auto-succeed payments
# Set to 'true' only for local development. NEVER set in production.
# NEXT_PUBLIC_DEV_PAYMENT=true

# Set to 'standalone' for Docker builds (omit for Vercel)
# NEXT_OUTPUT=standalone
