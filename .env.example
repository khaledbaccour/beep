# Database (use DATABASE_URL for production/Render, or individual vars for local Docker)
DATABASE_URL=
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=beep
POSTGRES_PASSWORD=changeme
POSTGRES_DB=beep

# Redis (use REDIS_URL for production/Upstash, or individual vars for local Docker)
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=changeme-jwt-secret
JWT_EXPIRATION=3600

# Gammal Tech Payment
GAMMAL_TECH_API_KEY=
GAMMAL_TECH_API_SECRET=
GAMMAL_TECH_WEBHOOK_SECRET=

# App
PORT=3001
API_PORT=3001
WEB_PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000

# PeerJS
PEERJS_PORT=9000
PEERJS_PATH=/peer

# TURN Server
TURN_SERVER_URL=turn:localhost:3478
TURN_USERNAME=beep
TURN_PASSWORD=changeme

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
